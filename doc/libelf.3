GElf_Off:Elf64_Off
GElf_Ehdr:Elf64_Ehdr
GElf_Shdr:Elf64_Shdr
GElf_Section:Elf64_Section
GElf_Sym:Elf64_Sym
GElf_Syminfo:Elf64_Syminfo
