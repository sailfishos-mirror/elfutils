GElf_Rela:Elf64_Rela
GElf_Relr:Elf64_Relr
GElf_Phdr:Elf64_Phdr
GElf_Chdr:Elf64_Chdr
GElf_Dyn:Elf64_Dyn
GElf_Verdef:Elf64_Verdef
